<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#5C18F5D4"
                android:centerColor="#2218F5D4"
                android:endColor="#11000000" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#3321E6D2"
                android:centerColor="#F20A1117"
                android:endColor="#E605080B" />
            <corners android:radius="29dp" />
            <stroke
                android:width="1dp"
                android:color="#66A7FFF5" />
        </shape>
    </item>
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#30FFFFFF"
                android:centerColor="#05000000"
                android:endColor="#00000000" />
            <corners android:radius="27dp" />
        </shape>
    </item>
</layer-list>
