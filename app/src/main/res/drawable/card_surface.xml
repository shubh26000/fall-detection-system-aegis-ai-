<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#3318F5D4"
                android:centerColor="#1000F5D4"
                android:endColor="#05000000" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#33151F25"
                android:centerColor="#EE081015"
                android:endColor="#AA04080C" />
            <corners android:radius="25dp" />
            <stroke
                android:width="1dp"
                android:color="#3D9EFDF2" />
        </shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#1CFFFFFF"
                android:centerColor="#00000000"
                android:endColor="#00000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
